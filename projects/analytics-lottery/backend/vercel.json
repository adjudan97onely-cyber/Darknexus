{
  "version": 2,
  "crons": [
    {
      "path": "/api/system/cron/refresh",
      "schedule": "30 10 * * *"
    },
    {
      "path": "/api/system/cron/prepare-next-draw",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/system/cron/refresh",
      "schedule": "30 18 * * *"
    }
  ],
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
