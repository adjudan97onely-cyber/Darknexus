# MongoDB Configuration
MONGO_URL=mongodb://localhost:27017
DB_NAME=darknexus

# JWT Authentication
JWT_SECRET_KEY=your_super_secret_key_change_this_in_production_min_32_chars_required

# OpenAI API (pour ChatGPT et Whisper)
OPENAI_API_KEY=sk-your-key-here

# Optional: Alternative LLM Provider
EMERGENT_LLM_KEY=optional_emergent_integrations_key

# Football Data API (TEMPS RÉEL - Gratuit sur https://www.football-data.org/)
FOOTBALL_DATA_KEY=YOUR_API_KEY_HERE

# Frontend URL (pour CORS)
FRONTEND_URL=http://localhost:3000

# Backend URL
BACKEND_URL=http://localhost:5000

# Database SQLite
DATABASE_URL=sqlite:///databases/predictions.db

# Environment
ENVIRONMENT=development
