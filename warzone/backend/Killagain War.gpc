    save_spvar(arv[39], -99, 99); save_spvar(arv[40], -99, 99); save_spvar(arv[41], -99, 99);
    save_spvar(arv[42], -99, 99); save_spvar(arv[43], -99, 99); save_spvar(arv[44], -99, 99);
    save_spvar(arv[45], -99, 99); save_spvar(arv[46], -99, 99); save_spvar(arv[47], -99, 99);
    save_spvar(arv[48], -99, 99); save_spvar(arv[49], -99, 99); save_spvar(arv[50], -99, 99);
    save_spvar(arv[51], -99, 99); save_spvar(arv[52], -99, 99); save_spvar(arv[53], -99, 99);
    save_spvar(arv[54], -99, 99); save_spvar(arv[55], -99, 99); save_spvar(arv[56], -99, 99);
    save_spvar(arv[57], -99, 99); save_spvar(arv[58], -99, 99); save_spvar(arv[59], -99, 99);
    save_spvar(arv[60], -99, 99); save_spvar(arv[61], -99, 99); save_spvar(arv[62], -99, 99);
    save_spvar(arv[63], -99, 99); save_spvar(arv[64], -99, 99); save_spvar(arv[65], -99, 99);
    save_spvar(arv[66], -99, 99); save_spvar(arv[67], -99, 99); save_spvar(arv[68], -99, 99);
    save_spvar(arv[69], -99, 99); save_spvar(arv[70], -99, 99); save_spvar(arv[71], -99, 99);
    save_spvar(arv[72], -99, 99); save_spvar(arv[73], -99, 99); save_spvar(arv[74], -99, 99);
    save_spvar(arv[75], -99, 99); save_spvar(arv[76], -99, 99); save_spvar(arv[77], -99, 99);
    save_spvar(arv[78], -99, 99); save_spvar(arv[79], -99, 99); save_spvar(arv[80], -99, 99);
