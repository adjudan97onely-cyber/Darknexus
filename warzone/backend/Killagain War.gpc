// ===================================================================
// FONCTIONS UTILITAIRES
// ===================================================================

function centre_x(int nb_car, int larg_car) {
    return (128 / 2) - ((nb_car * larg_car) / 2);
}

function recalculer_ar_scale() {
    ar_scale = 700 / game_sensitivity;
    ar_scale = ar_scale * 80 / game_fov;
    ar_scale = ar_scale * (100 + game_deadzone) / 100;
    if(game_response == 1) { ar_scale = ar_scale * 115 / 100; }  // Dynamique +15%
    if(game_response == 2) { ar_scale = ar_scale * 90  / 100; }  // Lineaire  -10%
    if(ar_scale < 50)  { ar_scale = 50; }
    if(ar_scale > 200) { ar_scale = 200; }
    // ADS scale : plus fort (sensi effective = game_sensitivity * ads_mult / 100)
    ar_scale_ads = ar_scale * 100 / ads_mult;
    if(ar_scale_ads < 50)  { ar_scale_ads = 50; }
    if(ar_scale_ads > 250) { ar_scale_ads = 250; }
}

function rand_gpc() {
    rand_seed = (rand_seed * 1103515245 + 12345) & 0x7FFFFFFF;
    return abs(rand_seed);
}

function correctStick(int stick_id) {
    cs_val = get_val(stick_id);
    if(cs_val >= -game_deadzone && cs_val <= game_deadzone) {
        set_val(stick_id, 0);
    } else if(cs_val < -game_deadzone) {
        set_val(stick_id, clamp((cs_val + game_deadzone) * 100 / (100 - game_deadzone), -100, 100));
    } else {
        set_val(stick_id, clamp((cs_val - game_deadzone) * 100 / (100 - game_deadzone), -100, 100));
    }
}

