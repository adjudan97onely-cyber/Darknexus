//  [RF]      weapon_rf_delay[] - delai RF specifique par arme (semi-autos)
//  [AR]      Toggle AR global SHARE+R1 avec feedback OLED + vibration
//  [AI]      aim_assist_paused auto sur SQUARE (plus de bug looting)
//  [MENU]    nav_cd : navigation menu fluide sans defilement trop rapide
//  [STICK]   correctStick() : deadzone propre avec clamp (BO7 method)
//  [SNIPER]  QuickScope + Auto Hold Breath sur snipers
//  [HUMAN]   Humanisation AR : micro-variations aleatoires (indetectable)
//  [TOGGLE]  L2+SHARE : desactive tout le script sans debrancher
//  [DEBUG]   TRACES actives (TRACE_1=RPM, TRACE_2=RumbleA, TRACE_3=Shots,
//                            TRACE_4=Index, TRACE_5=RF, TRACE_6=AR)
//  [MENU]    MOD+ menu (PAD+DOWN) : 15 features ON/OFF
//  [VEHICLE] SHARE+LEFT : Toggle mode vehicule (desactive mods combat)
//
// CONTROLES:
//  PAD + R2      = Menu selection arme (101 armes)
//  PAD + L2      = Menu reglage anti-recul manuel
//  PAD + DOWN    = Menu MOD+ (13 options ON/OFF)
//  PAD + UP      = Toggle Surprise Mode rapide
//  PAD + RIGHT   = Toggle Ultra Aggro
//  PAD + LEFT    = Menu Settings
//  SHARE + LEFT  = Toggle Mode Vehicule
//  SHARE + R1    = Toggle Anti-Recul global (feedback vibration)
//  L2 + SHARE    = Toggle Script ON/OFF complet
//  TRIANGLE      = Changer de profil (MK35 ISR / VST)
// ===================================================================

