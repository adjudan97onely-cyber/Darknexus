int aa_slowdown_zone = 28;          // Zone élargie pour couvrir le recul du Peacekeeper Mk1 (#1 méta)
int aa_micro_adjust = 10;           // AUGMENTÉ de 6 à 10 (corrections plus fortes)
int aa_trigger_time = 0;
int stick_rx = 0;
int stick_ry = 0;
