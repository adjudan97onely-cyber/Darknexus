const int noms_armesVALEUR[] = {4, 9, 9, 6, 10, 7, 7, 9, 5, 9, 5, 9, 8, 12, 15, 9, 11, 6, 6, 11, 3, 5, 9, 8, 8, 11, 5, 6, 9, 9, 12, 7, 6, 3, 3, 10, 6, 2, 3, 10, 7, 5, 15, 8, 4, 9, 12, 4, 6, 7, 6, 3, 5, 9, 12, 10, 9, 4, 5, 7, 6, 8, 3, 11, 9, 6, 13, 10, 5, 7, 7, 8, 10, 12, 7, 6, 4, 6, 4, 10, 10, 6, 7, 6, 4, 2, 3, 5, 9, 6, 10, 5, 5, 8, 6, 15, 12, 7, 10, 10, 12};

const string label_primaire[] = { "PRIMARY" };
const string label_secondaire[] = { "SECONDARY" };
const string label_choix_arme[] = { "LIST" };
