// HAIR TRIGGER ULTRA-SENSIBLE
int hair_trigger_actif = TRUE;
int hair_trigger_threshold = 28;    // RÉDUIT de 35 à 28 (S02 Reloaded: ADS plus rapide sur méta)

// JUMP SHOT INTELLIGENT
int jumpshot_delay_timer = 0;
int jumpshot_cooldown = 0;
int jumpshot_hold_time = 150;       // RÉDUIT de 200 à 150ms (plus réactif)

// RAPID FIRE TEMPS REEL (non bloquant)
int rapid_fire_delay = 22;          // Cadence injectee sur pressions partielles
int rf_full_press_threshold = 95;   // Maintien fort = passage direct sans rapid fire

// Slide Cancel settings
int sc_cancel_delay_time = 350;

// Auto Sprint settings
