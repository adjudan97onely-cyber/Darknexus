# Chronus Zen IDE — Configuration API

# ── OpenAI (ou endpoint compatible) ──────────────────────────────────────────
# Copiez ce fichier en ".env" et remplissez votre clé API.

# Clé API OpenAI (obligatoire pour l'explication de scripts)
OPENAI_API_KEY=sk-...

# Modèle à utiliser (optionnel — défaut : gpt-4o-mini)
# Alternatives : gpt-4o, gpt-3.5-turbo, ou tout modèle compatible
#OPENAI_MODEL=gpt-4o-mini

# Endpoint alternatif compatible OpenAI (optionnel)
# Exemples : Groq, Together AI, OpenRouter, Ollama local...
#OPENAI_BASE_URL=https://api.groq.com/openai/v1
